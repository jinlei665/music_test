# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=kuwo
DB_USER=root
DB_PASSWD=123456

# Flask 配置
SECRET_KEY=jin

# 邮件配置 (必须填入真实密码)
SMTP_USER=15508828680@163.com
SMTP_PASSWD=your_smtp_password_here

# Redis 配置 (可选，缓存用)
REDIS_URL=redis://localhost:6379/0

# 大模型 API (可选，AI 功能用)
OPENAI_API_KEY=your_openai_api_key
DASHSCOPE_API_KEY=your_dashscope_api_key
